# Slack Bot Tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# (선택) 보안용: 이 슬랙 유저 ID만 컴퓨터 켜기 명령을 허용합니다 (예: U12345678)
# 비워두면 모든 사용자의 명령을 허용합니다.
ALLOWED_SLACK_USER_ID=

# ipTime 공유기 원격 관리 설정
# IPTIME_URL 예시: http://myhome.iptime.org:38472 (포트 번호 포함)
IPTIME_URL=http://your-ddns.iptime.org:port
IPTIME_USER=admin
IPTIME_PASS=your_iptime_password

# PC 부팅 완료 알림을 보낼 슬랙 채널 (예: general, wol-bot, 채널ID C012345)
SLACK_NOTIFY_CHANNEL=general

# WOL 자동 로그인 (슬랙으로 절전 명령 시 다음 부팅 1회만 PIN 없이 자동 로그인)
# Microsoft 계정이면 이메일, 로컬 계정이면 사용자명
WINDOWS_USERNAME=your_username
WINDOWS_PASSWORD=your_microsoft_account_password

# 켜고자 하는 타겟 컴퓨터의 MAC 주소 (형식: AA:BB:CC:DD:EE:FF 또는 AA-BB-CC-DD-EE-FF)
TARGET_MAC=AA:BB:CC:DD:EE:FF
